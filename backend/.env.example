# Server Configuration
PORT=5000
NODE_ENV=development

# Database (Use your own local or Atlas URI)
MONGO_URI=mongodb://localhost:27017/portfolio

# JWT Secret (Use a strong unique value in real .env)
JWT_SECRET=CHANGE_ME_TO_A_LONG_SECRET_KEY

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_EMAIL=utkarsh.yash77@gmail.com

# Admin Credentials (Use real credentials ONLY in .env, never commit them)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
